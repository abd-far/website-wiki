---
export interface Props {
  sources: string[];
  date: Date;
}
const { sources, date } = Astro.props;
const formattedDate = date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' });
---

<div class="flex flex-wrap items-center gap-2 my-4">
  {sources.map(source => (
    <span class="text-xs tracking-wide uppercase border border-border text-muted px-2 py-0.5">
      {source}
    </span>
  ))}
  <span class="text-xs text-muted">· {formattedDate}</span>
</div>
