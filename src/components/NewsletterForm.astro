---
export interface Props {
  variant?: 'inline' | 'sidebar' | 'hero';
}
const { variant = 'inline' } = Astro.props;

const MAUTIC_FORM_ID = 'MAUTIC_FORM_ID';
const MAUTIC_URL = 'https://mautic.abdelouahebfarhi.com';
---

{variant === 'hero' && (
  <div class="border border-border bg-surface p-6">
    <h2 class="font-serif text-lg text-ink mb-1">Restez informé</h2>
    <p class="text-sm text-muted mb-5">
      Dernières recommandations cliniques pour médecins généralistes — newsletter gratuite.
    </p>
    <form action={`${MAUTIC_URL}/form/submit?formId=${MAUTIC_FORM_ID}`} method="POST" class="flex flex-col sm:flex-row gap-2">
      <input type="hidden" name="mauticform[formId]" value={MAUTIC_FORM_ID} />
      <input type="hidden" name="mauticform[return]" value="" />
      <input type="hidden" name="mauticform[formName]" value="newsletter_wiki" />
      <input
        type="text"
        name="mauticform[f_name]"
        placeholder="Prénom"
        required
        class="flex-1 px-3 py-2 border border-border bg-parchment text-ink text-sm placeholder:text-muted focus:outline-none focus:border-ink transition-colors"
      />
      <input
        type="email"
        name="mauticform[email]"
        placeholder="Email professionnel"
        required
        class="flex-1 px-3 py-2 border border-border bg-parchment text-ink text-sm placeholder:text-muted focus:outline-none focus:border-ink transition-colors"
      />
      <button
        type="submit"
        class="bg-ink text-parchment text-xs tracking-widest uppercase px-5 py-2 hover:bg-accent transition-colors whitespace-nowrap"
      >
        S'abonner
      </button>
    </form>
  </div>
)}

{variant === 'inline' && (
  <div class="border-l-2 border-accent pl-5 py-3 my-8">
    <p class="font-serif text-base text-ink mb-1">Cet article vous a été utile ?</p>
    <p class="text-sm text-muted mb-4">
      Recevez les prochaines mises à jour cliniques — newsletter pour médecins généralistes.
    </p>
    <form action={`${MAUTIC_URL}/form/submit?formId=${MAUTIC_FORM_ID}`} method="POST" class="flex flex-col sm:flex-row gap-2">
      <input type="hidden" name="mauticform[formId]" value={MAUTIC_FORM_ID} />
      <input type="hidden" name="mauticform[formName]" value="newsletter_wiki" />
      <input
        type="text"
        name="mauticform[f_name]"
        placeholder="Prénom"
        required
        class="flex-1 px-3 py-2 border border-border bg-parchment text-ink text-sm placeholder:text-muted focus:outline-none focus:border-ink transition-colors"
      />
      <input
        type="email"
        name="mauticform[email]"
        placeholder="Email"
        required
        class="flex-1 px-3 py-2 border border-border bg-parchment text-ink text-sm placeholder:text-muted focus:outline-none focus:border-ink transition-colors"
      />
      <button
        type="submit"
        class="bg-ink text-parchment text-xs tracking-widest uppercase px-5 py-2 hover:bg-accent transition-colors"
      >
        S'abonner
      </button>
    </form>
  </div>
)}

{variant === 'sidebar' && (
  <div class="border-t-2 border-accent pt-4">
    <p class="font-serif text-sm text-ink mb-1">Newsletter clinique</p>
    <p class="text-xs text-muted mb-4 leading-relaxed">
      Dernières recommandations pour médecins généralistes.
    </p>
    <form action={`${MAUTIC_URL}/form/submit?formId=${MAUTIC_FORM_ID}`} method="POST" class="flex flex-col gap-2">
      <input type="hidden" name="mauticform[formId]" value={MAUTIC_FORM_ID} />
      <input type="hidden" name="mauticform[formName]" value="newsletter_wiki" />
      <input
        type="text"
        name="mauticform[f_name]"
        placeholder="Prénom"
        required
        class="px-3 py-2 border border-border bg-parchment text-ink text-xs placeholder:text-muted focus:outline-none focus:border-ink transition-colors"
      />
      <input
        type="email"
        name="mauticform[email]"
        placeholder="Email"
        required
        class="px-3 py-2 border border-border bg-parchment text-ink text-xs placeholder:text-muted focus:outline-none focus:border-ink transition-colors"
      />
      <button
        type="submit"
        class="bg-ink text-parchment text-xs tracking-widest uppercase px-3 py-2 hover:bg-accent transition-colors"
      >
        S'abonner
      </button>
    </form>
  </div>
)}
