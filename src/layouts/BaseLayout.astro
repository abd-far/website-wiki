---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  jsonLd?: object;
}

const { title, description = "Références cliniques pour médecins généralistes — recommandations 2026", canonicalUrl, jsonLd } = Astro.props;
const siteUrl = 'https://wiki.abdelouahebfarhi.com';
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <title>{title} — Wiki Médical</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Wiki Médical — Dr. Abdelouaheb Farhi",
      "url": siteUrl,
      "description": "Références cliniques pour médecins généralistes, basées sur les recommandations 2026",
      "author": {
        "@type": "Person",
        "name": "Dr. Abdelouaheb Farhi",
        "jobTitle": "Médecin praticien"
      }
    })} />
  </head>
  <body class="bg-parchment text-ink font-sans min-h-screen flex flex-col">

    <!-- Navigation -->
    <header class="border-b border-border bg-parchment sticky top-0 z-10">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="font-serif text-lg text-ink hover:text-accent transition-colors tracking-tight">
          Wiki Médical
        </a>
        <nav class="flex items-center gap-7">
          <a href="/diabete/" class="nav-link text-sm text-muted hover:text-ink transition-colors">Diabète</a>
          <a href="/anesthesie/" class="nav-link text-sm text-muted hover:text-ink transition-colors">Anesthésie</a>
          <a
            href="/s-abonner"
            class="text-xs tracking-widest uppercase border border-ink text-ink px-4 py-1.5 hover:bg-ink hover:text-parchment transition-colors"
          >
            S'abonner
          </a>
        </nav>
      </div>
    </header>

    <!-- Contenu principal -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-border mt-20 py-10">
      <div class="max-w-5xl mx-auto px-6">
        <div class="flex flex-col sm:flex-row justify-between gap-8">
          <div>
            <p class="font-serif text-ink mb-2">Dr. Abdelouaheb Farhi</p>
            <p class="text-xs text-muted leading-relaxed max-w-xs">
              Ressource de référence clinique pour les professionnels de santé.
              Les informations sont basées sur les recommandations officielles
              et ne remplacent pas le jugement clinique.
            </p>
          </div>
          <div class="flex flex-col gap-2 text-sm">
            <a href="/s-abonner" class="text-muted hover:text-accent transition-colors">Newsletter clinique</a>
            <a href="/diabete/" class="text-muted hover:text-accent transition-colors">Diabète</a>
            <a href="/anesthesie/" class="text-muted hover:text-accent transition-colors">Anesthésie</a>
            <a href="https://abdelouahebfarhi.com" class="text-muted hover:text-accent transition-colors">abdelouahebfarhi.com</a>
          </div>
        </div>
        <div class="mt-8 pt-6 border-t border-border text-xs text-muted">
          © {new Date().getFullYear()} Dr. Abdelouaheb Farhi
        </div>
      </div>
    </footer>

  </body>
</html>
