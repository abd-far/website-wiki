---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SourceBadge from '../components/SourceBadge.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

export interface Props {
  title: string;
  description?: string;
  category: string;
  sources: string[];
  date: Date;
  related: string[];
  slug: string;
}

const { title, description, category, sources, date, related, slug } = Astro.props;

const categoryLabels: Record<string, string> = {
  diabete: 'Diabète',
  anesthesie: 'Anesthésie',
  cardiologie: 'Cardiologie',
  pneumologie: 'Pneumologie',
};

const categoryLabel = categoryLabels[category] ?? category;
const siteUrl = 'https://wiki.abdelouahebfarhi.com';
const canonicalUrl = `${siteUrl}/${category}/${slug}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": title,
  "description": description ?? title,
  "url": canonicalUrl,
  "dateModified": date.toISOString(),
  "inLanguage": "fr",
  "author": {
    "@type": "Person",
    "name": "Dr. Abdelouaheb Farhi",
    "jobTitle": "Médecin praticien"
  },
  "medicalAudience": {
    "@type": "MedicalAudience",
    "audienceType": "Clinician"
  },
  "isPartOf": {
    "@type": "WebSite",
    "name": "Wiki Médical — Dr. Abdelouaheb Farhi",
    "url": siteUrl
  }
};
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl} jsonLd={jsonLd}>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <div class="flex gap-8">
      <!-- Article principal -->
      <article class="flex-1 min-w-0">
        <Breadcrumbs items={[
          { label: 'Accueil', href: '/' },
          { label: categoryLabel, href: `/${category}/` },
          { label: title },
        ]} />

        <h1 class="text-2xl font-bold text-gray-900 mb-3 leading-tight">{title}</h1>

        <SourceBadge sources={sources} date={date} />

        <!-- Corps de l'article (markdown rendu) -->
        <div class="prose prose-blue max-w-none mt-6
          prose-h2:text-xl prose-h2:font-bold prose-h2:mt-8 prose-h2:mb-3 prose-h2:text-gray-800
          prose-h3:text-lg prose-h3:font-semibold prose-h3:mt-6 prose-h3:mb-2 prose-h3:text-gray-700
          prose-p:text-gray-700 prose-p:leading-relaxed prose-p:mb-4
          prose-ul:pl-5 prose-li:text-gray-700 prose-li:mb-1
          prose-strong:text-gray-900
          prose-a:text-blue-700 prose-a:hover:underline">
          <slot />
        </div>

        <!-- CTA newsletter inline -->
        <NewsletterForm variant="inline" />

        <!-- Articles connexes -->
        {related.length > 0 && (
          <div class="mt-8 border-t border-gray-200 pt-6">
            <h2 class="text-base font-semibold text-gray-700 mb-3">Questions connexes</h2>
            <ul class="space-y-2">
              {related.map(relSlug => (
                <li>
                  <a href={`/${category}/${relSlug}`} class="text-blue-700 hover:underline text-sm">
                    → {relSlug.replace(/-/g, ' ')}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Signature auteur -->
        <div class="mt-8 border-t border-gray-200 pt-4 text-xs text-gray-500">
          Rédigé par <strong>Dr. Abdelouaheb Farhi</strong>, médecin praticien,
          d'après les recommandations {sources.join(', ')}.
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="hidden lg:block w-64 flex-shrink-0">
        <div class="sticky top-20 space-y-6">
          <NewsletterForm variant="sidebar" />

          <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
            <p class="font-semibold text-sm text-gray-700 mb-2">Catégories</p>
            <ul class="space-y-1 text-sm">
              <li><a href="/diabete/" class="text-blue-700 hover:underline">Diabète</a></li>
              <li><a href="/anesthesie/" class="text-blue-700 hover:underline">Anesthésie</a></li>
            </ul>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
