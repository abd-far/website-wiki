---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SourceBadge from '../components/SourceBadge.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

export interface Props {
  title: string;
  description?: string;
  category: string;
  sources: string[];
  date: Date;
  related: string[];
  slug: string;
}

const { title, description, category, sources, date, related, slug } = Astro.props;

const categoryLabels: Record<string, string> = {
  diabete: 'Diabète',
  anesthesie: 'Anesthésie',
  cardiologie: 'Cardiologie',
  pneumologie: 'Pneumologie',
};

const categoryLabel = categoryLabels[category] ?? category;
const siteUrl = 'https://wiki.abdelouahebfarhi.com';
const canonicalUrl = `${siteUrl}/${category}/${slug}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": title,
  "description": description ?? title,
  "url": canonicalUrl,
  "dateModified": date.toISOString(),
  "inLanguage": "fr",
  "author": {
    "@type": "Person",
    "name": "Dr. Abdelouaheb Farhi",
    "jobTitle": "Médecin praticien"
  },
  "medicalAudience": {
    "@type": "MedicalAudience",
    "audienceType": "Clinician"
  },
  "isPartOf": {
    "@type": "WebSite",
    "name": "Wiki Médical — Dr. Abdelouaheb Farhi",
    "url": siteUrl
  }
};
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl} jsonLd={jsonLd}>
  <div class="max-w-5xl mx-auto px-6 py-10">
    <div class="flex gap-12">

      <!-- Article principal -->
      <article class="flex-1 min-w-0 anim-1">
        <Breadcrumbs items={[
          { label: 'Accueil', href: '/' },
          { label: categoryLabel, href: `/${category}/` },
          { label: title },
        ]} />

        <h1 class="font-serif text-2xl font-bold text-ink leading-tight mb-4 mt-2">
          {title}
        </h1>

        <SourceBadge sources={sources} date={date} />

        <!-- Corps de l'article -->
        <div class="wiki-prose mt-8">
          <slot />
        </div>

        <!-- CTA newsletter inline -->
        <div class="mt-10">
          <NewsletterForm variant="inline" />
        </div>

        <!-- Articles connexes -->
        {related.length > 0 && (
          <div class="mt-10 pt-6 border-t border-border">
            <p class="text-xs tracking-widest uppercase text-muted mb-4">Questions connexes</p>
            <ul class="space-y-2">
              {related.map(relSlug => (
                <li>
                  <a
                    href={`/${category}/${relSlug}`}
                    class="text-sm text-ink hover:text-accent transition-colors border-b border-transparent hover:border-accent"
                  >
                    {relSlug.replace(/-/g, ' ')}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Signature auteur -->
        <div class="mt-10 pt-5 border-t border-border">
          <p class="text-xs text-muted">
            Rédigé par <span class="text-ink font-semibold">Dr. Abdelouaheb Farhi</span>, médecin praticien,
            d'après les recommandations {sources.join(', ')}.
          </p>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="hidden lg:block w-60 flex-shrink-0">
        <div class="sticky top-24 space-y-8 anim-2">

          <NewsletterForm variant="sidebar" />

          <div>
            <p class="text-xs tracking-widest uppercase text-muted mb-3">Spécialités</p>
            <ul class="space-y-2 text-sm">
              <li>
                <a href="/diabete/" class="nav-link text-ink hover:text-accent transition-colors">Diabète</a>
              </li>
              <li>
                <a href="/anesthesie/" class="nav-link text-ink hover:text-accent transition-colors">Anesthésie</a>
              </li>
            </ul>
          </div>

        </div>
      </aside>

    </div>
  </div>
</BaseLayout>
