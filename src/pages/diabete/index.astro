---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('diabete').catch(() => []);
const sorted = articles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Diabète & Endocrinologie — Questions cliniques"
  description="Réponses aux questions des médecins généralistes sur le diabète de type 2 : traitement 2026, SGLT2i, GLP-1, tirzepatide, CGM, insuline. ADA 2026, HAS 2024."
>
  <div class="max-w-3xl mx-auto px-6 py-10">

    <nav class="flex items-center gap-1.5 text-xs text-muted mb-8">
      <a href="/" class="hover:text-accent transition-colors">Accueil</a>
      <span class="text-border">·</span>
      <span class="text-ink">Diabète</span>
    </nav>

    <div class="anim-1">
      <p class="text-xs tracking-widest uppercase text-muted mb-3">Spécialité</p>
      <h1 class="font-serif text-3xl font-bold text-ink mb-2 leading-tight">Diabète & Endocrinologie</h1>
      <p class="text-muted text-sm mb-10">
        {sorted.length} question{sorted.length !== 1 ? 's' : ''} — ADA 2026 · HAS 2024 · ESC-EASD 2023
      </p>
    </div>

    <div class="divide-y divide-border anim-2">
      {sorted.map((article, i) => (
        <a
          href={`/diabete/${article.data.slug ?? article.slug}`}
          class="article-card flex items-start gap-6 py-5 px-3 -mx-3 group"
        >
          <span class="font-serif text-xl text-border font-bold tabular-nums mt-0.5 select-none w-8 flex-shrink-0 text-right">
            {String(i + 1).padStart(2, '0')}
          </span>
          <div class="flex-1 min-w-0">
            <p class="text-ink group-hover:text-accent transition-colors font-medium leading-snug mb-2">
              {article.data.title}
            </p>
            <div class="flex gap-3 flex-wrap items-center">
              {article.data.sources.slice(0, 3).map(s => (
                <span class="text-xs text-muted">{s}</span>
              ))}
              {article.data.tags.slice(0, 2).map(t => (
                <span class="text-xs border border-border text-muted px-2 py-0.5">{t}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>

    {sorted.length === 0 && (
      <p class="text-muted text-center py-16 font-serif italic">Articles à venir — revenez bientôt.</p>
    )}

  </div>
</BaseLayout>
