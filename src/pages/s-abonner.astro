---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
---

<BaseLayout
  title="S'abonner — Newsletter pour médecins généralistes"
  description="Recevez les dernières recommandations cliniques pour médecins généralistes. Newsletter gratuite, basée sur les guidelines 2026."
>
  <div class="max-w-2xl mx-auto px-6 py-20 anim-1">

    <p class="text-xs tracking-widest uppercase text-muted mb-5">Newsletter clinique</p>
    <h1 class="font-serif text-3xl font-bold text-ink mb-4 leading-tight">
      Restez informé des<br />dernières recommandations
    </h1>
    <p class="text-muted mb-8 leading-relaxed max-w-md">
      Newsletter pour médecins généralistes — résumés cliniques actionnables,
      basés sur les guidelines ADA, HAS, ESC et autres sociétés savantes.
    </p>

    <ul class="space-y-2 text-sm text-ink mb-10">
      <li class="flex items-start gap-3">
        <span class="text-accent mt-0.5 flex-shrink-0">—</span>
        Nouvelles recommandations décryptées en pratique
      </li>
      <li class="flex items-start gap-3">
        <span class="text-accent mt-0.5 flex-shrink-0">—</span>
        Médicaments et protocoles mis à jour
      </li>
      <li class="flex items-start gap-3">
        <span class="text-accent mt-0.5 flex-shrink-0">—</span>
        Articles Q&A publiés sur ce site
      </li>
      <li class="flex items-start gap-3">
        <span class="text-accent mt-0.5 flex-shrink-0">—</span>
        Gratuit, sans spam
      </li>
    </ul>

    <NewsletterForm variant="hero" />

    <p class="text-xs text-muted mt-6">
      Vos données ne sont jamais partagées. Désinscription en un clic.
    </p>
  </div>
</BaseLayout>
