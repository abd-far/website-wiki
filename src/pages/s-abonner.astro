---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
---

<BaseLayout
  title="S'abonner — Newsletter pour médecins généralistes"
  description="Recevez les dernières recommandations cliniques pour médecins généralistes. Newsletter gratuite, basée sur les guidelines 2026."
>
  <div class="max-w-2xl mx-auto px-4 py-16 text-center">
    <h1 class="text-3xl font-bold text-gray-900 mb-4">
      Restez informé des dernières recommandations
    </h1>
    <p class="text-lg text-gray-600 mb-6">
      Newsletter pour médecins généralistes — résumés cliniques actionnables,
      basés sur les guidelines ADA, HAS, ESC et autres sociétés savantes.
    </p>
    <ul class="text-left inline-block text-gray-600 mb-10 space-y-2 text-sm">
      <li>✓ Nouvelles recommandations décryptées en pratique</li>
      <li>✓ Médicaments et protocoles mis à jour</li>
      <li>✓ Articles Q&A publiés sur ce site</li>
      <li>✓ Gratuit, sans spam</li>
    </ul>

    <div class="max-w-md mx-auto">
      <NewsletterForm variant="hero" />
    </div>

    <p class="text-xs text-gray-400 mt-6">
      Vos données ne sont jamais partagées. Désinscription en un clic.
    </p>
  </div>
</BaseLayout>
