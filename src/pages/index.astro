---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

const allDiabete = await getCollection('diabete').catch(() => []);
const allAnesthesie = await getCollection('anesthesie').catch(() => []);

const allArticles = [...allDiabete, ...allAnesthesie]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);
---

<BaseLayout
  title="Wiki Médical — Références cliniques pour médecins généralistes"
  description="Réponses aux questions cliniques des médecins généralistes, basées sur les recommandations 2026 (ADA, HAS, ESC). Diabète, anesthésie, cardiologie."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-blue-700 to-blue-900 text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-3xl font-bold mb-4 leading-tight">
        Références cliniques pour médecins généralistes
      </h1>
      <p class="text-blue-100 text-lg mb-8">
        Réponses aux questions cliniques du quotidien — basées sur les recommandations 2026.
      </p>
      <NewsletterForm variant="hero" />
    </div>
  </section>

  <!-- Catégories -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-xl font-bold text-gray-800 mb-6">Thèmes disponibles</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <a href="/diabete/" class="border border-gray-200 rounded-xl p-6 hover:border-blue-400 hover:shadow-md transition group">
        <div class="text-2xl mb-2">🩺</div>
        <h3 class="font-bold text-gray-800 group-hover:text-blue-700 mb-1">Diabète & Endocrinologie</h3>
        <p class="text-sm text-gray-500">Traitement DT2, SGLT2i, GLP-1, tirzepatide, CGM, insuline — ADA 2026, HAS 2024</p>
      </a>
      <a href="/anesthesie/" class="border border-gray-200 rounded-xl p-6 hover:border-blue-400 hover:shadow-md transition group">
        <div class="text-2xl mb-2">💉</div>
        <h3 class="font-bold text-gray-800 group-hover:text-blue-700 mb-1">Anesthésie & Obstétrique</h3>
        <p class="text-sm text-gray-500">Vasopresseurs, rachianesthésie, hypotension spinale, césarienne — recommandations 2026</p>
      </a>
    </div>
  </section>

  <!-- Derniers articles -->
  {allArticles.length > 0 && (
    <section class="max-w-5xl mx-auto px-4 pb-12">
      <h2 class="text-xl font-bold text-gray-800 mb-6">Dernières publications</h2>
      <div class="space-y-3">
        {allArticles.map(article => (
          <a
            href={`/${article.collection}/${article.data.slug ?? article.slug}`}
            class="block border border-gray-200 rounded-lg p-4 hover:border-blue-400 hover:shadow-sm transition"
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-medium text-gray-800 hover:text-blue-700">{article.data.title}</p>
                <div class="flex gap-2 mt-1">
                  <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded capitalize">
                    {article.collection}
                  </span>
                  {article.data.sources.slice(0, 2).map(s => (
                    <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded">{s}</span>
                  ))}
                </div>
              </div>
              <span class="text-xs text-gray-400 whitespace-nowrap">
                {article.data.date.toLocaleDateString('fr-FR', { month: 'short', year: 'numeric' })}
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
