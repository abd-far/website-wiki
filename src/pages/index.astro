---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

const allDiabete = await getCollection('diabete').catch(() => []);
const allAnesthesie = await getCollection('anesthesie').catch(() => []);

const allArticles = [...allDiabete, ...allAnesthesie]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);
---

<BaseLayout
  title="Wiki Médical — Références cliniques pour médecins généralistes"
  description="Réponses aux questions cliniques des médecins généralistes, basées sur les recommandations 2026 (ADA, HAS, ESC). Diabète, anesthésie, cardiologie."
>

  <!-- Hero -->
  <section class="border-b border-border py-20 px-6 anim-1">
    <div class="max-w-3xl mx-auto">
      <p class="text-xs tracking-widest uppercase text-muted mb-5">Références cliniques · 2026</p>
      <h1 class="font-serif text-4xl font-bold text-ink leading-tight mb-5">
        Questions cliniques<br />pour médecins généralistes
      </h1>
      <p class="text-lg text-muted mb-10 max-w-xl leading-relaxed">
        Réponses aux questions du quotidien — basées sur les recommandations
        ADA 2026, HAS 2024, ESC-EASD 2023.
      </p>
      <NewsletterForm variant="hero" />
    </div>
  </section>

  <!-- Spécialités -->
  <section class="max-w-5xl mx-auto px-6 py-14 anim-2">
    <p class="text-xs tracking-widest uppercase text-muted mb-6">Spécialités</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-border">
      <a href="/diabete/" class="group bg-parchment p-8 hover:bg-surface transition-colors">
        <p class="text-xs tracking-widest uppercase text-muted mb-3 group-hover:text-accent transition-colors">Diabète & Endocrinologie</p>
        <p class="font-serif text-xl text-ink mb-3 leading-snug">
          Traitement DT2, SGLT2i,<br />GLP-1, tirzepatide, CGM
        </p>
        <p class="text-sm text-muted">ADA 2026 · HAS 2024 · ESC-EASD 2023</p>
      </a>
      <a href="/anesthesie/" class="group bg-parchment p-8 hover:bg-surface transition-colors">
        <p class="text-xs tracking-widest uppercase text-muted mb-3 group-hover:text-accent transition-colors">Anesthésie & Obstétrique</p>
        <p class="font-serif text-xl text-ink mb-3 leading-snug">
          Vasopresseurs, rachianesthésie,<br />hypotension spinale
        </p>
        <p class="text-sm text-muted">Recommandations 2026</p>
      </a>
    </div>
  </section>

  <!-- Dernières publications -->
  {allArticles.length > 0 && (
    <section class="max-w-5xl mx-auto px-6 pb-16 anim-3">
      <div class="flex items-baseline justify-between mb-6">
        <p class="text-xs tracking-widest uppercase text-muted">Dernières publications</p>
        <span class="text-xs text-muted">{allArticles.length} article{allArticles.length > 1 ? 's' : ''}</span>
      </div>
      <div class="divide-y divide-border">
        {allArticles.map((article, i) => (
          <a
            href={`/${article.collection}/${article.data.slug ?? article.slug}`}
            class="article-card flex items-start gap-6 py-5 px-3 -mx-3 group"
          >
            <span class="font-serif text-2xl text-border font-bold tabular-nums mt-0.5 select-none w-8 flex-shrink-0 text-right">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="flex-1 min-w-0">
              <p class="text-ink group-hover:text-accent transition-colors font-medium leading-snug mb-2">
                {article.data.title}
              </p>
              <div class="flex items-center gap-3 flex-wrap">
                <span class="text-xs tracking-wide uppercase text-muted border border-border px-2 py-0.5">
                  {article.collection}
                </span>
                {article.data.sources.slice(0, 2).map(s => (
                  <span class="text-xs text-muted">{s}</span>
                ))}
              </div>
            </div>
            <span class="text-xs text-muted whitespace-nowrap flex-shrink-0">
              {article.data.date.toLocaleDateString('fr-FR', { month: 'short', year: 'numeric' })}
            </span>
          </a>
        ))}
      </div>
    </section>
  )}

</BaseLayout>
